{
  "functions": {
    "source": "lex-backend",
    "runtime": "nodejs18",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" install"
    ]
  },
  "hosting": {
    "public": "lex-frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "lexBackend"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
